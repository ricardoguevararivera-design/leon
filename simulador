<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Alerta Anónima - Simulador de Doble Vista Activa</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/ol@v8.2.0/ol.css">
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #0b0f19;
            color: #f8fafc;
            display: flex;
            height: 100vh;
            overflow: hidden;
        }

        /* DISEÑO DE PANTALLA DIVIDIDA */
        .panel-split {
            flex: 1;
            display: flex;
            flex-direction: column;
            height: 100%;
            position: relative;
        }

        /* Lado Izquierdo: Aplicación Ciudadana */
        #vista-ciudadano {
            background-color: #111827;
            border-right: 4px solid #3b82f6;
        }

        /* Lado Derecho: Centro de Comando Policial */
        #vista-policia {
            background-color: #0f172a;
        }

        /* ENCABEZADOS */
        .panel-header {
            padding: 15px 20px;
            font-size: 1.1rem;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 2px solid #1f2937;
        }
        .badge {
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: bold;
        }
        .badge-citizen { background-color: #2563eb; color: white; }
        .badge-police { background-color: #1e3a8a; color: #93c5fd; border: 1px solid #3b82f6; }

        /* ÁREA DE CONTENIDO */
        .panel-body {
            flex: 1;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        #map {
            width: 100%;
            height: 100%;
        }

        /* CONTROLES CIUDADANOS Overlay */
        .citizen-controls {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            background-color: rgba(17, 24, 39, 0.95);
            padding: 15px;
            border-radius: 12px;
            border: 1px solid #3b82f6;
            width: 85%;
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
            z-index: 1000;
        }
        .btn-report {
            width: 100%;
            background-color: #ef4444;
            color: white;
            border: none;
            padding: 12px;
            font-weight: bold;
            border-radius: 6px;
            cursor: pointer;
            text-transform: uppercase;
            transition: background 0.2s;
        }
        .btn-report:hover { background-color: #dc2626; }
        .btn-report:disabled { background-color: #4b5563; cursor: not-allowed; }

        /* INTERFAZ POLICIAL */
        .police-dashboard {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            height: 100%;
            box-sizing: border-box;
            overflow-y: auto;
        }
        .no-alert-box {
            border: 2px dashed #334155;
            padding: 40px 20px;
            text-align: center;
            color: #64748b;
            border-radius: 8px;
            margin-top: 50px;
        }
        .alert-active-box {
            background-color: rgba(239, 68, 68, 0.1);
            border: 2px solid #ef4444;
            padding: 15px;
            border-radius: 8px;
            animation: pulse-border 2s infinite;
        }
        @keyframes pulse-border {
            0% { border-color: #ef4444; }
            50% { border-color: #7f1d1d; }
            100% { border-color: #ef4444; }
        }

        .unit-list {
            list-style: none;
            padding: 0;
            margin: 10px 0 0 0;
        }
        .unit-card {
            background-color: #1e293b;
            padding: 12px;
            margin-bottom: 8px;
            border-radius: 6px;
            border: 1px solid #334155;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .unit-name { font-weight: bold; font-size: 0.95rem; }
        .unit-distance {
            color: #10b981;
            font-weight: bold;
            background-color: rgba(16, 185, 129, 0.1);
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 0.8rem;
        }
        .badge-live-alert {
            background-color: #ef4444;
            color: white;
            padding: 4px 8px;
            border-radius: 4px;
            font-weight: bold;
            font-size: 0.8rem;
            animation: blink 1s infinite;
        }
        @keyframes blink { 0%{opacity:1;} 50%{opacity:0.3;} 100%{opacity:1;} }
    </style>
</head>
<body>

    <div id="vista-ciudadano" class="panel-split">
        <div class="panel-header">
            <span>1. Interfaz Ciudadana</span>
            <span class="badge badge-citizen">Anónimo (Sin Registro)</span>
        </div>
        <div class="panel-body">
            <div id="map"></div>
            
            <div class="citizen-controls">
                <p style="margin: 0 0 10px 0; font-size: 0.85rem; color: #9ca3af; text-align: center;">
                    Paso 1: Toca el mapa para fijar las coordenadas del delito de forma discreta.
                </p>
                <button id="btn-enviar" class="btn-report" disabled onclick="dispararAlertaPolicial()">
                    Enviar Reporte Táctico Anónimo
                </button>
            </div>
        </div>
    </div>

    <div id="vista-policia" class="panel-split">
        <div class="panel-header">
            <span>2. Consola de Despacho Operativo</span>
            <span class="badge badge-police">Centro de Monitoreo C4</span>
        </div>
        <div class="panel-body" style="background-color: #0b0f19;">
            <div class="police-dashboard">
                
                <div id="no-alert" class="no-alert-box">
                    📡 ESCANEANDO PERÍMETRO URBANO EN VIVO...<br>
                    <span style="font-size: 0.8rem; display:block; margin-top:10px; color:#475569;">
                        Esperando que ingrese una alerta desde el cuadrante del ciudadano.
                    </span>
                </div>

                <div id="alert-active" class="alert-active-box" style="display: none;">
                    <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #ef4444; padding-bottom: 8px;">
                        <span class="badge-live-alert">🚨 NUEVA ALERTA RADIAL ENTRANTE</span>
                        <span style="font-size: 0.85rem; font-weight: bold;" id="display-coords"></span>
                    </div>
                    <p style="font-size: 0.9rem; color: #cbd5e1; margin: 12px 0 4px 0;">
                        <strong>Algoritmo Radial Completo:</strong> Reporte distribuído de forma simultánea a las 10 unidades de cuadrante con mayor ventaja geográfica:
                    </p>
                    <ul id="police-units" class="unit-list"></ul>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/ol@v8.2.0/dist/ol.js"></script>
    <script>
        // Coordenadas simuladas fijas de Patrullas en Bogotá
        const basePatrullas = [
            { id: "Patrulla Cuadrante 12 - Chapinero Central", lat: 4.6486, lon: -74.0611 },
            { id: "Binomio de Motos 04 - Chapinero Alto", lat: 4.6521, lon: -74.0553 },
            { id: "Patrulla Cuadrante 02 - Teusaquillo", lat: 4.6281, lon: -74.0782 },
            { id: "Unidad Lince Táctica - Parkway", lat: 4.6325, lon: -74.0721 },
            { id: "Patrulla Cuadrante 45 - Centro Internacional", lat: 4.6156, lon: -74.0684 },
            { id: "Patrulla Cuadrante 08 - Usaquén", lat: 4.7012, lon: -74.0305 },
            { id: "Binomio de Motos 19 - Unicentro", lat: 4.7025, lon: -74.0415 },
            { id: "Patrulla Cuadrante 33 - Suba Centro", lat: 4.7412, lon: -74.0845 },
            { id: "Patrulla Cuadrante 11 - Engativá", lat: 4.6912, lon: -74.1124 },
            { id: "Patrulla Cuadrante 07 - Fontibón", lat: 4.6654, lon: -74.1385 },
            { id: "Unidad Operativa Movil - Salitre", lat: 4.6542, lon: -74.1085 },
            { id: "Patrulla Cuadrante 21 - Kennedy", lat: 4.6184, lon: -74.1524 },
            { id: "Binomio de Motos 55 - Av. Primera de Mayo", lat: 4.5945, lon: -74.1215 },
            { id: "Patrulla Cuadrante 09 - Bosa", lat: 4.6085, lon: -74.1945 },
            { id: "Patrulla Cuadrante 60 - Ciudad Bolívar", lat: 4.5724, lon: -74.1553 }
        ];

        let coordenadaSeleccionada = null;

        // Inicializar mapa centrado en Bogotá
        const map = new ol.Map({
            target: 'map',
            layers: [
                new ol.layer.Tile({ source: new ol.source.OSM() })
            ],
            view: new ol.View({
                center: ol.proj.fromLonLat([-74.0721, 4.6325]),
                zoom: 12
            })
        });

        // Capturar clic del ciudadano
        map.on('click', function (evt) {
            const coords = ol.proj.toLonLat(evt.coordinate);
            coordenadaSeleccionada = { lon: coords[0], lat: coords[1] };
            
            // Habilitar el botón de envío tras seleccionar el punto
            const btn = document.getElementById('btn-enviar');
            btn.removeAttribute('disabled');
            btn.innerText = "Enviar Reporte (Ubicación Fijada)";
            btn.style.backgroundColor = "#22c55e"; // Cambia a verde instructivo
        });

        // Fórmula Matemática Haversine (Cálculo de Distancias GPS en KM)
        function calcularDistanciaKM(lat1, lon1, lat2, lon2) {
            const R = 6371; 
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                      Math.sin(dLon/2) * Math.sin(dLon/2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            return R * c; 
        }

        // ACCIÓN CLAVE: El Ciudadano envía y la Policía lo ve de inmediato
        function dispararAlertaPolicial() {
            if (!coordenadaSeleccionada) return;

            const latCiu = coordenadaSeleccionada.lat;
            const lonCiu = coordenadaSeleccionada.lon;

            // Mostrar coordenadas en la pantalla del policía
            document.getElementById('display-coords').innerText = `GPS: ${latCiu.toFixed(4)}, ${lonCiu.toFixed(4)}`;

            // Procesar backend en vivo: mapear distancias contra el punto de la denuncia
            const calculos = basePatrullas.map(p => {
                const dist = calcularDistanciaKM(latCiu, lonCiu, p.lat, p.lon);
                return { name: p.id, distancia: dist };
            });

            // Ordenar por cercanía (menor a mayor)
            calculos.sort((a, b) => a.distancia - b.distancia);

            // Filtrar estrictamente el Top 10 solicitado
            const top10 = calculos.slice(0, 10);

            // Renderizar la lista dinámicamente en el lado de la policía
            const listContainer = document.getElementById('police-units');
            listContainer.innerHTML = ''; // Vaciar alertas previas

            top10.forEach(u => {
                const li = document.createElement('li');
                li.className = 'unit-card';

                const textoDistancia = u.distancia < 1 
                    ? `${(u.distancia * 1000).toFixed(0)} metros` 
                    : `${u.distancia.toFixed(2)} km`;

                li.innerHTML = `
                    <span class="unit-name">${u.name}</span>
                    <span class="unit-distance">a ${textoDistancia}</span>
                `;
                listContainer.appendChild(li);
            });

            // Cambiar estados visuales en la consola de la policía
            document.getElementById('no-alert').style.display = 'none';
            document.getElementById('alert-active').style.display = 'block';

            // Resetear el botón del ciudadano para simular el éxito del envío discreto
            const btn = document.getElementById('btn-enviar');
            btn.setAttribute('disabled', 'true');
            btn.innerText = "Reporte Transmitido con Éxito";
            btn.style.backgroundColor = "#4b5563";
        }
    </script>
</body>
</html>
